{
  "name": "datasphere-innovation-ia-platform-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:report": "npx playwright show-report",
    "test:e2e:headed": "cross-env E2E_HEADLESS=false npx playwright test",
    "test:e2e:debug": "cross-env PWDEBUG=1 npx playwright test",
    "test:e2e:smoke": "npx playwright test e2e/api-smoke.spec.ts",
    "test:e2e:auth": "npx playwright test e2e/auth.spec.ts",
    "test:e2e:nav": "npx playwright test e2e/navigation.spec.ts",
    "test:e2e:workflow": "npx playwright test e2e/workflow.spec.ts",
    "test:e2e:robust": "npx playwright test e2e/ui-robustness.spec.ts",
    "test:e2e:ci": "cross-env CI=true npx playwright test --reporter=github"
  },
  "dependencies": {
    "@vitejs/plugin-react": "5.1.1",
    "lucide-react": "0.475.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "vite": "5.4.21"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/react": "18.3.23",
    "@types/react-dom": "18.3.7",
    "cross-env": "10.1.0",
    "eslint": "9.39.1",
    "typescript": "5.9.3"
  }
}
