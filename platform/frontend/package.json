{
  "name": "datasphere-innovation-ia-platform-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:headed": "E2E_HEADLESS=false playwright test",
    "test:e2e:debug": "PWDEBUG=1 playwright test",
    "test:e2e:smoke": "playwright test e2e/api-smoke.spec.ts",
    "test:e2e:auth": "playwright test e2e/auth.spec.ts",
    "test:e2e:nav": "playwright test e2e/navigation.spec.ts",
    "test:e2e:workflow": "playwright test e2e/workflow.spec.ts",
    "test:e2e:robust": "playwright test e2e/ui-robustness.spec.ts",
    "test:e2e:ci": "CI=true playwright test --reporter=github"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest"
  }
}
