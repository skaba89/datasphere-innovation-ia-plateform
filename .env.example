# DataSphere Innovation IA Platform — Development Environment
# Copy to .env and adjust. NEVER commit secrets to Git.

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=DataSphere Innovation IA Platform
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
# CORS allowed origins (comma-separated, no spaces)
# Dev: keep this line as-is — localhost is always allowed in APP_ENV=development
# Prod: set to your real domain, e.g. https://app.datasphere-innovation.fr
# IMPORTANT: if you set this variable, include ALL origins you need (frontend port included)
# ⚠ Do NOT set to empty string — that would block all requests
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SECRET_KEY=change-me-with-openssl-rand-hex-64
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=datasphere_platform
POSTGRES_USER=datasphere
POSTGRES_PASSWORD=change-me

# ── DATABASE ──────────────────────────────────────────────────────────────────
# DOCKER COMPOSE : utiliser le nom de service "postgres" (jamais "localhost")
DATABASE_URL=postgresql+psycopg2://datasphere:change-me@postgres:5432/datasphere_platform

# DEV LOCAL (hors Docker) : utiliser localhost
# DATABASE_URL=postgresql+psycopg2://datasphere:change-me@localhost:5432/datasphere_platform

# ──────────────────────────────────────────────────────────────────────────────
# LLM PROVIDERS — CHAÎNE DE FALLBACK AUTOMATIQUE
# Priorité : Gratuit → Quasi-gratuit → Budget → Standard → Premium
# L'app essaie chaque provider dans l'ordre. Si l'un échoue (rate limit,
# timeout, erreur API), le suivant prend le relais automatiquement.
# Laissez vide les providers que vous n'utilisez pas.
# ──────────────────────────────────────────────────────────────────────────────

# TIER 1 — GRATUIT (100% free, no credit card needed)
# ─────────────────────────────────────────────────────
# GLM-4-Flash (ZhipuAI) — entièrement GRATUIT, API OpenAI-compatible
# Inscription : https://open.bigmodel.ai → "API Keys"
GLM_API_KEY=

# TIER 2 — QUASI-GRATUIT (free tier très généreux)
# ──────────────────────────────────────────────────
# Groq (Llama 3.3 70B) — 14 400 req/jour GRATUIT, latence <1s
# Inscription : https://console.groq.com
GROQ_API_KEY=

# Google Gemini Flash — 1500 req/jour GRATUIT, contexte 1M tokens
# Inscription : https://aistudio.google.com/apikey
GEMINI_API_KEY=

# TIER 3 — BUDGET (payant mais très peu cher ~0.18$/M tokens)
# ─────────────────────────────────────────────────────────────
# Together AI (Llama 3.3 70B Turbo) — open-source, très peu cher
# Inscription : https://api.together.xyz
TOGETHER_API_KEY=

# Alibaba Qwen (qwen-turbo) — multilingue, langues africaines, peu cher
# Inscription : https://dashscope.aliyuncs.com
QWEN_API_KEY=

# TIER 4 — STANDARD (rapport qualité/prix correct)
# ──────────────────────────────────────────────────
# OpenRouter — accès à 200+ modèles (certains gratuits avec suffix :free)
# Inscription : https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Mistral AI — français natif, souveraineté UE, RGPD
# Inscription : https://console.mistral.ai
MISTRAL_API_KEY=

# Cohere Command R — RAG natif, analyse documentaire
# Inscription : https://dashboard.cohere.com
COHERE_API_KEY=

# Perplexity Sonar — recherche web en temps réel
# Inscription : https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# TIER 5 — PREMIUM (meilleure qualité, dernier recours)
# ───────────────────────────────────────────────────────
# OpenAI GPT-4o-mini — fiable, bien documenté
# Inscription : https://platform.openai.com
OPENAI_API_KEY=

# Anthropic Claude — meilleur raisonnement, utilisé en dernier recours
# Inscription : https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Surcharges optionnelles ───────────────────────────────────────────────────
# Personnaliser l'ordre de priorité des providers (séparé par virgules)
# LLM_PROVIDER_ORDER=groq,gemini,glm,together,qwen,openrouter,mistral,openai,anthropic

# Forcer un provider spécifique pour chaque type de tâche
# LLM_TASK_CONTEXT_ANALYSIS=glm
# LLM_TASK_GO_NO_GO_RECOMMENDATION=groq
# LLM_TASK_TENDER_REQUIREMENTS_REVIEW=gemini
# LLM_TASK_DELIVERABLE_PLAN=mistral
# LLM_TASK_COMPLIANCE_MATRIX=glm
# LLM_TASK_COMMERCIAL_PROPOSAL=groq

# Surcharger le modèle par défaut d'un provider
# LLM_MODEL_GROQ=llama-3.1-8b-instant
# LLM_MODEL_GEMINI=gemini-1.5-pro
# LLM_MODEL_GLM=glm-4-air
# LLM_MODEL_ANTHROPIC=claude-3-5-sonnet-20241022

# ── Paramètres LLM globaux ────────────────────────────────────────────────────
LLM_MAX_TOKENS=1500
LLM_TIMEOUT_SECONDS=60

# ── Scheduler ─────────────────────────────────────────────────────────────────
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Europe/Paris
SCHEDULER_AUTO_EXECUTE_INTERVAL_MINUTES=5
SCHEDULER_AUTO_PLAN_INTERVAL_MINUTES=3
SCHEDULER_AUTO_DRAFT_INTERVAL_MINUTES=10
SCHEDULER_DAILY_REPORT_HOUR=7
SCHEDULER_MAX_ACTIONS_PER_RUN=10

# ── SMTP (laisser vide pour le mode preview-only) ─────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=DataSphere Innovation <noreply@datasphere-innovation.fr>
SMTP_TLS=true

# ── Resend (alternative SMTP, gratuit 3000 emails/mois) ───────────────────────
# Inscription : https://resend.com — si défini, prioritaire sur SMTP
RESEND_API_KEY=

# ── Stripe (paiements) ──────────────────────────────────────────────────────
# Mode TEST pour le développement : clés commençant par sk_test_ / whsec_test_
# Mode LIVE pour la production : clés commençant par sk_live_ / whsec_
# Dashboard : https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Sentry (observabilité erreurs) ─────────────────────────────────────────
# Inscription : https://sentry.io — plan gratuit suffisant pour démarrer
SENTRY_DSN=

# ── Setup / bootstrap admin ──────────────────────────────────────────────────
# Token requis pour /setup/run, /setup/fix-db, /auth/diagnose-login
# Générer une valeur aléatoire forte (ex: openssl rand -hex 32)
SETUP_SECRET_KEY=
SETUP_ENABLED=true
