# DataSphere Innovation IA Platform - environment example

APP_NAME=DataSphere Innovation IA Platform
APP_ENV=development
APP_DEBUG=true

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SECRET_KEY=change-me-in-local-env
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5433
POSTGRES_DB=datasphere_platform
POSTGRES_USER=datasphere
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg2://datasphere:change-me@postgres:5432/datasphere_platform

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Optional object storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=documents

# AI providers - keep real keys outside Git
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=
